[
  {
    "name": "court_name",
    "label": "Court Name",
    "type": "text",
    "required": true,
    "hint": "Enter full name of the court (e.g., Sessions Court)"
  },
  {
    "name": "court_location",
    "label": "Court Location",
    "type": "text",
    "required": true,
    "hint": "Enter city and state of the court"
  },
  {
    "name": "judge_name",
    "label": "Judge Name",
    "type": "text",
    "hint": "Enter presiding judge name (if known)",
    "required": false
  },
  {
    "name": "case_title",
    "label": "Case Title",
    "type": "text",
    "hint": "e.g., State vs Applicant Name",
    "required": true
  },
  {
    "name": "case_number",
    "label": "Case / Crime Number",
    "type": "text",
    "required": true,
    "hint": "Enter case or crime number"
  },
  {
    "name": "police_station",
    "label": "Police Station",
    "type": "text",
    "required": true,
    "hint": "Enter police station name"
  },
  {
    "name": "fir_number",
    "label": "FIR Number",
    "type": "text",
    "hint": "Enter FIR number",
    "required": false
  },
  {
    "name": "fir_date",
    "label": "FIR Date",
    "type": "date",
    "hint": "Select FIR registration date",
    "required": false
  },
  {
    "name": "legal_sections",
    "label": "Applicable Acts and Sections",
    "type": "group",
    "repeatable": true,
    "min": 1,
    "required": true,
    "fields": [
      {
        "name": "act_name",
        "label": "Act",
        "type": "dropdown",
        "required": true,
        "options": [
          "IPC",
          "CrPC",
          "Evidence Act",
          "BNS (Bharatiya Nyaya Sanhita)",
          "BNSS (Bharatiya Nagarik Suraksha Sanhita)",
          "BSA (Bharatiya Sakshya Adhiniyam)",
          "Other"
        ],
        "hint": "Select the applicable Act"
      },
      {
        "name": "other_act_name",
        "label": "Other Act Name",
        "type": "text",
        "required": true,
        "hint": "Enter the name of the other Act",
        "show_if": "act_name == 'Other'"
      },
      {
        "name": "section_numbers",
        "label": "Section Number(s)",
        "type": "text",
        "required": true,
        "hint": "Enter section numbers, e.g. 420, 406, 438"
      }
    ],
    "hint": "Add one or more Act/Section combinations"
  },
  {
    "name": "hybrid_law_transition_note",
    "label": "Old Law / New Law Transition Note",
    "type": "textarea",
    "required": false,
    "hint": "Mention if the offence predates July 1, 2024 and involves IPC/CrPC with BNSS procedure"
  },
  {
    "name": "applicant_name",
    "label": "Applicant Full Name",
    "type": "text",
    "required": true,
    "hint": "Enter full legal name"
  },
  {
    "name": "applicant_father_name",
    "label": "Father's / Spouse Name",
    "type": "text",
    "hint": "Enter father's or spouse's name",
    "required": false
  },
  {
    "name": "applicant_gender",
    "label": "Gender",
    "type": "dropdown",
    "required": false,
    "options": [
      "Male",
      "Female",
      "Other"
    ],
    "hint": "Select gender"
  },
  {
    "name": "applicant_age",
    "label": "Age",
    "type": "number",
    "hint": "Enter age in years",
    "required": true
  },
  {
    "name": "applicant_occupation",
    "label": "Occupation",
    "type": "text",
    "hint": "Enter occupation",
    "required": false
  },
  {
    "name": "applicant_address",
    "label": "Residential Address",
    "type": "textarea",
    "required": true,
    "hint": "Enter complete residential address with PIN code"
  },
  {
    "name": "passport_photo_attached",
    "label": "Applicant Passport Size Photo Attached",
    "type": "boolean",
    "hint": "Tick if applicant passport size photo is affixed",
    "required": false
  },
  {
    "name": "bail_type",
    "label": "Type of Bail",
    "type": "dropdown",
    "required": true,
    "options": [
      "Regular Bail",
      "Anticipatory Bail",
      "Interim Bail",
      "Default Bail"
    ],
    "hint": "Select type of bail"
  },
  {
    "name": "arrest_status",
    "label": "Arrest Status",
    "type": "dropdown",
    "options": [
      "Arrested",
      "Not Arrested"
    ],
    "hint": "Select arrest status",
    "required": true
  },
  {
    "name": "arrest_date",
    "label": "Arrest Date",
    "type": "date",
    "hint": "Select date of arrest",
    "required": true,
    "show_if": "arrest_status == 'Arrested'"
  },
  {
    "name": "custody_details",
    "label": "Custody Details",
    "type": "textarea",
    "hint": "Mention whether in judicial or police custody",
    "required": true,
    "show_if": "arrest_status == 'Arrested'"
  },
  {
    "name": "date_of_remand",
    "label": "Date of Remand",
    "type": "date",
    "hint": "Select remand date",
    "required": true,
    "show_if": "bail_type == 'Default Bail'"
  },
  {
    "name": "total_days_in_custody",
    "label": "Total Days in Custody",
    "type": "number",
    "hint": "Enter total days in custody",
    "required": true,
    "show_if": "bail_type == 'Default Bail'"
  },
  {
    "name": "default_bail_basis",
    "label": "Default Bail Basis",
    "type": "textarea",
    "hint": "Mention non-filing of charge sheet within the statutory 60/90 day period",
    "required": true,
    "show_if": "bail_type == 'Default Bail'"
  },
  {
    "name": "apprehension_of_arrest",
    "label": "Apprehension of Arrest",
    "type": "textarea",
    "hint": "Explain why the applicant believes arrest is imminent and the accusation is malicious",
    "required": true,
    "show_if": "bail_type == 'Anticipatory Bail'"
  },
  {
    "name": "interim_bail_start_date",
    "label": "Interim Bail Start Date",
    "type": "date",
    "hint": "Select interim bail start date",
    "required": true,
    "show_if": "bail_type == 'Interim Bail'"
  },
  {
    "name": "interim_bail_end_date",
    "label": "Interim Bail End Date",
    "type": "date",
    "hint": "Select interim bail end date",
    "required": true,
    "show_if": "bail_type == 'Interim Bail'"
  },
  {
    "name": "interim_bail_reason",
    "label": "Reason for Interim Bail",
    "type": "textarea",
    "hint": "Mention urgent reason such as funeral, wedding, or medical treatment",
    "required": true,
    "show_if": "bail_type == 'Interim Bail'"
  },
  {
    "name": "case_facts",
    "label": "Brief Facts of the Case",
    "type": "textarea",
    "required": true,
    "hint": "Provide concise case background"
  },
  {
    "name": "co_accused_details",
    "label": "Co-accused Details",
    "type": "textarea",
    "hint": "Mention co-accused names and whether they have been granted bail or are pending",
    "required": false
  },
  {
    "name": "medical_history_infirmity",
    "label": "Medical History / Infirmity",
    "type": "textarea",
    "hint": "Mention illness, infirmity, disability, or medical grounds, if any",
    "required": false
  },
  {
    "name": "grounds_for_bail",
    "label": "Grounds for Bail",
    "type": "group",
    "repeatable": true,
    "min": 1,
    "fields": [
      {
        "name": "ground",
        "label": "Ground",
        "type": "textarea",
        "required": true,
        "hint": "e.g., false implication, no criminal history, medical grounds, parity with co-accused"
      }
    ],
    "hint": "Add multiple legal grounds",
    "required": true
  },
  {
    "name": "previous_bail_applied",
    "label": "Previously Applied for Bail",
    "type": "boolean",
    "hint": "Has the applicant applied for bail earlier?",
    "required": false
  },
  {
    "name": "previous_bail_details",
    "label": "Previous Bail Details",
    "type": "textarea",
    "hint": "Mention court and result of previous application",
    "required": true,
    "show_if": "previous_bail_applied == true"
  },
  {
    "name": "criminal_antecedents",
    "label": "Criminal Antecedents",
    "type": "textarea",
    "hint": "Mention past criminal record, if any",
    "required": false
  },
  {
    "name": "surety_amount",
    "label": "Surety Amount",
    "type": "number",
    "hint": "Enter proposed surety amount",
    "required": false,
    "show_if": "bail_type == 'Regular Bail'"
  },
  {
    "name": "surety_details",
    "label": "Surety Details",
    "type": "textarea",
    "hint": "Enter surety person details",
    "required": false,
    "show_if": "bail_type == 'Regular Bail'"
  },
  {
    "name": "surety_passport_photo_attached",
    "label": "Surety Passport Size Photo Attached",
    "type": "boolean",
    "hint": "Tick if surety passport size photo is affixed",
    "required": false,
    "show_if": "bail_type == 'Regular Bail'"
  },
  {
    "name": "undertaking",
    "label": "Undertaking by Applicant",
    "type": "textarea",
    "hint": "e.g., will cooperate, not tamper evidence, attend court",
    "required": true
  },
  {
    "name": "annexures",
    "label": "Annexures / List of Documents",
    "type": "group",
    "repeatable": true,
    "fields": [
      {
        "name": "document_name",
        "label": "Document Name",
        "type": "text",
        "required": true,
        "hint": "e.g., FIR Copy, Remand Order, Medical Report"
      },
      {
        "name": "document_details",
        "label": "Document Details",
        "type": "text",
        "required": false,
        "hint": "Enter document number, date, or short description"
      }
    ],
    "hint": "Add annexures attached with the bail application",
    "required": false
  },
  {
    "name": "advocate_name",
    "label": "Advocate Name",
    "type": "text",
    "required": true,
    "hint": "Enter advocate full name"
  },
  {
    "name": "advocate_enrollment_number",
    "label": "Enrollment Number",
    "type": "text",
    "hint": "Enter Bar Council enrollment number",
    "required": false
  },
  {
    "name": "advocate_address",
    "label": "Advocate Address",
    "type": "textarea",
    "hint": "Enter advocate office address",
    "required": false
  },
  {
    "name": "prayer",
    "label": "Prayer",
    "type": "textarea",
    "hint": "Formal request to grant bail",
    "required": true
  },
  {
    "name": "verification_date",
    "label": "Verification Date",
    "type": "date",
    "hint": "Select verification date",
    "required": true
  },
  {
    "name": "verification_place",
    "label": "Verification Place",
    "type": "text",
    "hint": "Enter place of verification",
    "required": true
  },
  {
    "name": "applicant_signature",
    "label": "Applicant Signature",
    "type": "text",
    "hint": "Enter applicant name as signature",
    "required": false
  },
  {
    "name": "advocate_signature",
    "label": "Advocate Signature",
    "type": "text",
    "hint": "Enter advocate name as signature",
    "required": false
  }
]
