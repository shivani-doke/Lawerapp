  {
    "name": "testators",
    "label": "Testator Details",
    "type": "group",
    "repeatable": true,
    "min": 1,
    "max": 2,
    "required": true,
    "fields": [
      {
        "name": "testator_name",
        "label": "Testator Full Name",
        "type": "text",
        "required": true,
        "hint": "Enter testator full name"
      },
      {
        "name": "testator_age",
        "label": "Age",
        "type": "number",
        "hint": "Enter age",
        "required": false
      },
      {
        "name": "testator_occupation",
        "label": "Occupation",
        "type": "text",
        "hint": "Enter occupation",
        "required": false
      },
      {
        "name": "testator_address",
        "label": "Residential Address",
        "type": "textarea",
        "required": true,
        "hint": "Enter residential address"
      },
      {
        "name": "testator_id_proof",
        "label": "ID Proof (Aadhaar/PAN)",
        "type": "text",
        "hint": "Enter ID proof (Aadhaar/PAN)",
        "required": false
      }
    ],
    "hint": "Add one or two testators",
    "required": true
  },
  {
    "name": "marital_status",
    "label": "Marital Status",
    "type": "dropdown",
    "options": [
      "Single",
      "Married",
      "Widowed",
      "Divorced"
    ],
    "hint": "Select marital status",
    "required": false
  },
