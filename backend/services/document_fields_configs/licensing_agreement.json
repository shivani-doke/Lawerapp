[
  {
    "name": "effective_date",
    "label": "Effective Date",
    "type": "date",
    "hint": "Select agreement effective date",
    "required": true
  },
  {
    "name": "execution_place",
    "label": "Execution Place",
    "type": "text",
    "hint": "Enter city and state where agreement is executed",
    "required": true
  },
  {
    "name": "licensor_name",
    "label": "Licensor Name",
    "type": "text",
    "hint": "Enter full legal name",
    "required": true
  },
  {
    "name": "licensor_address",
    "label": "Licensor Address",
    "type": "textarea",
    "hint": "Enter complete address",
    "required": true
  },
  {
    "name": "licensor_type",
    "label": "Licensor Type",
    "type": "dropdown",
    "options": ["Individual", "Company", "LLP", "Partnership"],
    "hint": "Select type of licensor",
    "required": true
  },
  {
    "name": "licensee_name",
    "label": "Licensee Name",
    "type": "text",
    "hint": "Enter full legal name",
    "required": true
  },
  {
    "name": "licensee_address",
    "label": "Licensee Address",
    "type": "textarea",
    "hint": "Enter complete address",
    "required": true
  },
  {
    "name": "licensee_type",
    "label": "Licensee Type",
    "type": "dropdown",
    "options": ["Individual", "Company", "LLP", "Partnership"],
    "hint": "Select type of licensee",
    "required": true
  },
  {
    "name": "agreement_title",
    "label": "Agreement Title",
    "type": "text",
    "hint": "e.g., Software License Agreement",
    "required": false
  },
  {
    "name": "licensed_ip",
    "label": "Licensed Intellectual Property",
    "type": "textarea",
    "hint": "Describe IP (software, trademark, content, etc.)",
    "required": true
  },
  {
    "name": "ip_type",
    "label": "IP Type",
    "type": "dropdown",
    "options": [
      "Software",
      "Trademark",
      "Copyright",
      "Patent",
      "Design",
      "Other"
    ],
    "hint": "Select type of IP",
    "required": true
  },
  {
    "name": "patent_numbers",
    "label": "Patent Numbers / Application Numbers",
    "type": "textarea",
    "hint": "List patent registration or application numbers covered by the license",
    "required": false,
    "show_if": "ip_type == 'Patent'"
  },
  {
    "name": "ownership_confirmation",
    "label": "Ownership Confirmation",
    "type": "textarea",
    "hint": "Confirm licensor owns the IP",
    "required": true
  },
  {
    "name": "license_type",
    "label": "License Type",
    "type": "dropdown",
    "options": [
      "Exclusive",
      "Non-Exclusive",
      "Sole"
    ],
    "hint": "Select license type",
    "required": true
  },
  {
    "name": "exclusivity_carve_outs",
    "label": "Exclusivity Carve-outs / Retained Rights",
    "type": "textarea",
    "hint": "List rights the licensor retains despite granting the license",
    "required": false,
    "show_if": "license_type == 'Sole' || license_type == 'Non-Exclusive'"
  },
  {
    "name": "license_scope",
    "label": "License Scope",
    "type": "textarea",
    "hint": "Define permitted use, field, and limitations",
    "required": true
  },
  {
    "name": "territory",
    "label": "Territory",
    "type": "multiselect",
    "options": [
      "India",
      "United States",
      "Europe",
      "United Kingdom",
      "Asia-Pacific",
      "Middle East",
      "Africa",
      "Worldwide",
      "Rest of World"
    ],
    "hint": "Select applicable territories",
    "required": true
  },
  {
    "name": "territory_details",
    "label": "Territory Details",
    "type": "textarea",
    "hint": "Add specific country names, exclusions, or field-of-use restrictions for the selected territory",
    "required": false
  },
  {
    "name": "duration",
    "label": "Duration",
    "type": "text",
    "hint": "Enter term (e.g., 3 years, perpetual)",
    "required": true
  },
  {
    "name": "effective_from",
    "label": "Effective From",
    "type": "date",
    "hint": "Select start date",
    "required": true
  },
  {
    "name": "consideration_type",
    "label": "Consideration Type",
    "type": "dropdown",
    "options": [
      "Royalty",
      "Lump Sum",
      "Both",
      "Free"
    ],
    "hint": "Select payment structure",
    "required": true
  },
  {
    "name": "consideration_currency",
    "label": "Consideration Currency",
    "type": "dropdown",
    "options": ["INR", "USD", "EUR", "GBP"],
    "hint": "Select the currency for payment obligations",
    "required": false,
    "show_if": "consideration_type == 'Lump Sum' || consideration_type == 'Both'"
  },
  {
    "name": "consideration_amount",
    "label": "Consideration Amount",
    "type": "number",
    "hint": "Enter fixed payment amount",
    "required": false,
    "show_if": "consideration_type == 'Lump Sum' || consideration_type == 'Both'"
  },
  {
    "name": "royalty_terms",
    "label": "Royalty Terms",
    "type": "textarea",
    "hint": "Enter percentage, frequency, reporting cycle, and calculation method",
    "required": false,
    "show_if": "consideration_type == 'Royalty' || consideration_type == 'Both'"
  },
  {
    "name": "audit_rights",
    "label": "Audit Rights",
    "type": "textarea",
    "hint": "Specify whether the licensor may inspect the licensee's books and records for royalty verification",
    "required": false,
    "show_if": "consideration_type == 'Royalty' || consideration_type == 'Both'"
  },
  {
    "name": "payment_terms",
    "label": "Payment Terms",
    "type": "textarea",
    "hint": "Specify payment schedule and mode",
    "required": false
  },
  {
    "name": "sub_licensing_allowed",
    "label": "Sub-Licensing Allowed",
    "type": "boolean",
    "hint": "Can licensee sub-license the IP?",
    "required": true
  },
  {
    "name": "sublicensing_approval",
    "label": "Sublicensing Approval Requirement",
    "type": "dropdown",
    "options": [
      "Prior Written Consent Required",
      "Permitted Without Consent",
      "Permitted Subject to Conditions",
      "Custom"
    ],
    "hint": "Choose whether the licensor must approve sublicenses",
    "required": false,
    "show_if": "sub_licensing_allowed == true"
  },
  {
    "name": "sublicensing_conditions",
    "label": "Sublicensing Conditions",
    "type": "textarea",
    "hint": "State any conditions for sublicensing, such as same terms, limited scope, or liability back-to-back",
    "required": false,
    "show_if": "sub_licensing_allowed == true"
  },
  {
    "name": "restrictions",
    "label": "Restrictions",
    "type": "textarea",
    "hint": "Specify restrictions on use",
    "required": false
  },
  {
    "name": "quality_control",
    "label": "Quality Control",
    "type": "textarea",
    "hint": "Specify quality standards, approval rights, and brand usage controls",
    "required": false,
    "show_if": "ip_type == 'Trademark'"
  },
  {
    "name": "maintenance_support",
    "label": "Technical Support / Maintenance",
    "type": "textarea",
    "hint": "State whether updates, patches, bug fixes, or support services are included",
    "required": false,
    "show_if": "ip_type == 'Software'"
  },
  {
    "name": "infringement_notification",
    "label": "Infringement Notification & Enforcement",
    "type": "textarea",
    "hint": "Specify who must notify, control, and fund action against third-party infringement",
    "required": false
  },
  {
    "name": "intellectual_property_rights",
    "label": "IP Rights Ownership",
    "type": "textarea",
    "hint": "Clarify ownership remains with licensor",
    "required": true
  },
  {
    "name": "confidentiality_clause",
    "label": "Confidentiality Clause",
    "type": "textarea",
    "hint": "Confidentiality obligations",
    "required": false
  },
  {
    "name": "indemnity_clause",
    "label": "Indemnity Clause",
    "type": "textarea",
    "hint": "Specify indemnification responsibilities",
    "required": false
  },
  {
    "name": "limitation_of_liability",
    "label": "Limitation of Liability",
    "type": "textarea",
    "hint": "Limit liabilities of parties",
    "required": false
  },
  {
    "name": "force_majeure",
    "label": "Force Majeure",
    "type": "textarea",
    "hint": "State events beyond reasonable control that excuse performance delays or failures",
    "required": false
  },
  {
    "name": "termination_clause",
    "label": "Termination Clause",
    "type": "textarea",
    "hint": "Conditions for termination",
    "required": true
  },
  {
    "name": "post_termination_obligations",
    "label": "Post-Termination Obligations",
    "type": "textarea",
    "hint": "Obligations after termination",
    "required": false
  },
  {
    "name": "dispute_resolution",
    "label": "Dispute Resolution",
    "type": "textarea",
    "hint": "Specify arbitration/mediation process",
    "required": true
  },
  {
    "name": "notice_details",
    "label": "Notice Details",
    "type": "textarea",
    "hint": "Provide the email and physical addresses where legal notices must be sent",
    "required": false
  },
  {
    "name": "governing_law",
    "label": "Governing Law",
    "type": "text",
    "hint": "Enter applicable law (e.g., Laws of India)",
    "required": true,
    "default": "Laws of India"
  },
  {
    "name": "jurisdiction",
    "label": "Jurisdiction",
    "type": "text",
    "hint": "Enter court jurisdiction",
    "required": true
  },
  {
    "name": "witness_details",
    "label": "Witness Details",
    "type": "group",
    "repeatable": true,
    "min": 2,
    "max": 2,
    "required": true,
    "fields": [
      {
        "name": "name",
        "label": "Witness Name",
        "type": "text",
        "required": true,
        "hint": "Enter full name of witness"
      },
      {
        "name": "address",
        "label": "Address",
        "type": "textarea",
        "required": true,
        "hint": "Enter address of witness"
      }
    ]
  }
]
