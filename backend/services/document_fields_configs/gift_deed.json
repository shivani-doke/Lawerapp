[
  {
    "name": "execution_date",
    "label": "Execution Date",
    "type": "date",
    "hint": "Select the date on which the gift deed is executed",
    "required": true
  },
  {
    "name": "execution_place",
    "label": "Execution Place (City)",
    "type": "text",
    "hint": "Enter city where deed is executed",
    "required": true
  },

  {
    "name": "donor_details",
    "label": "Donor Details",
    "type": "group",
    "repeatable": true,
    "required": true,
    "fields": [
      {
        "name": "name",
        "label": "Donor Name",
        "type": "text",
        "required": true,
        "hint": "Enter full legal name of donor"
      },
      {
        "name": "age",
        "label": "Age",
        "type": "number",
        "required": true,
        "hint": "Enter age in years"
      },
      {
        "name": "occupation",
        "label": "Occupation",
        "type": "text",
        "required": true,
        "hint": "Enter occupation"
      },
      {
        "name": "address",
        "label": "Address",
        "type": "textarea",
        "required": true,
        "hint": "Enter complete residential address"
      },
      {
        "name": "pan",
        "label": "PAN Number",
        "type": "text",
        "validation": "pan",
        "hint": "Enter PAN (ABCDE1234F)"
      },
      {
        "name": "aadhaar",
        "label": "Aadhaar Number",
        "type": "text",
        "validation": "aadhaar",
        "hint": "Enter 12-digit Aadhaar number"
      },
      {
        "name": "share",
        "label": "Ownership Share (%)",
        "type": "percentage",
        "required": true,
        "hint": "Enter donor's ownership percentage"
      }
    ]
  },

  {
    "name": "donee_details",
    "label": "Donee Details",
    "type": "group",
    "repeatable": true,
    "required": true,
    "fields": [
      {
        "name": "name",
        "label": "Donee Name",
        "type": "text",
        "required": true,
        "hint": "Enter full legal name of donee"
      },
      {
        "name": "age",
        "label": "Age",
        "type": "number",
        "required": true,
        "hint": "Enter age in years"
      },
      {
        "name": "occupation",
        "label": "Occupation",
        "type": "text",
        "required": true,
        "hint": "Enter occupation"
      },
      {
        "name": "address",
        "label": "Address",
        "type": "textarea",
        "required": true,
        "hint": "Enter complete residential address"
      },
      {
        "name": "pan",
        "label": "PAN Number",
        "type": "text",
        "validation": "pan",
        "hint": "Enter PAN (ABCDE1234F)"
      },
      {
        "name": "aadhaar",
        "label": "Aadhaar Number",
        "type": "text",
        "validation": "aadhaar",
        "hint": "Enter 12-digit Aadhaar number"
      },
      {
        "name": "share",
        "label": "Gift Share (%)",
        "type": "percentage",
        "required": true,
        "hint": "Enter share being gifted to this donee"
      },
      {
        "name": "guardian_name",
        "label": "Guardian Name",
        "type": "text",
        "hint": "Enter guardian name if donee is minor",
        "show_if": "age < 18"
      }
    ]
  },

  {
    "name": "relationship",
    "label": "Relationship between Donor and Donee",
    "type": "dropdown",
    "options": ["Father", "Mother", "Brother", "Sister", "Spouse", "Other"],
    "hint": "Select relationship between donor and donee",
    "required": true
  },

  {
    "name": "gift_nature",
    "label": "Nature of Gift",
    "type": "dropdown",
    "options": ["Voluntary", "Without Consideration"],
    "hint": "Select nature of gift",
    "required": true
  },
  {
    "name": "consideration",
    "label": "Consideration",
    "type": "text",
    "hint": "Gift is made without monetary consideration",
    "default": "Without any monetary consideration",
    "required": true
  },
  {
    "name": "possession_status",
    "label": "Possession Status",
    "type": "radio",
    "options": ["Given", "Will be Given"],
    "hint": "Select possession transfer status",
    "required": true
  },
  {
    "name": "acceptance",
    "label": "Accepted by Donee",
    "type": "boolean",
    "hint": "Confirm donee acceptance",
    "required": true
  },
  {
    "name": "market_value",
    "label": "Market Value",
    "type": "currency",
    "hint": "Enter current market value of property",
    "required": true
  },

  {
    "name": "property_type",
    "label": "Property Type",
    "type": "dropdown",
    "options": ["Flat", "Land", "House", "Commercial"],
    "hint": "Select property type",
    "required": true
  },
  {
    "name": "property_number",
    "label": "Property Number",
    "type": "text",
    "hint": "Enter flat/property number",
    "required": true
  },
  {
    "name": "floor_number",
    "label": "Floor Number",
    "type": "text",
    "hint": "Enter floor number if applicable"
  },
  {
    "name": "building_name",
    "label": "Building Name",
    "type": "text",
    "hint": "Enter building or society name",
    "required": true
  },
  {
    "name": "survey_number",
    "label": "Survey Number",
    "type": "text",
    "hint": "Enter survey or plot number",
    "required": true
  },
  {
    "name": "location",
    "label": "Location",
    "type": "text",
    "hint": "Enter area and city",
    "required": true
  },
  {
    "name": "district",
    "label": "District",
    "type": "text",
    "hint": "Enter district name",
    "required": true
  },
  {
    "name": "flat_area",
    "label": "Area (sq ft)",
    "type": "number",
    "hint": "Enter area in square feet",
    "required": true
  },
  {
    "name": "terrace_area",
    "label": "Terrace Area",
    "type": "number",
    "hint": "Enter terrace area if applicable"
  },
  {
    "name": "parking_details",
    "label": "Parking Details",
    "type": "text",
    "hint": "Enter parking details if any"
  },

  {
    "name": "ownership_description",
